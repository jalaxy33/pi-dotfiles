{
  "providers": {
    "opencode-go": {
      "compat": {
        "sendSessionAffinityHeaders": true
      }
    },
    "deepseek": {
      "compat": {
        "supportsLongCacheRetention": true,
        "sendSessionAffinityHeaders": true
      }
    },
    "zai": {
      "compat": {
        "sendSessionAffinityHeaders": true
      }
    },
    "ark": {
      "baseUrl": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "api": "openai-completions",
      "apiKey": "$ARK_API_KEY",
      "models": [
        {
          "id": "glm-latest",
          "name": "glm-latest",
          "reasoning": true,
          "input": [
            "text"
          ],
          "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
          },
          "contextWindow": 1024000,
          "maxTokens": 128000,
          "compat": {
            "supportsStore": false,
            "supportsDeveloperRole": false,
            "supportsReasoningEffort": true,
            "thinkingFormat": "zai",
            "zaiToolStream": true,
            "sendSessionAffinityHeaders": true
          }
        }
      ]
    }
  }
}
