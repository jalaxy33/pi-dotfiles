{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.13.2/schema.json",
  "permissionGate": {
    "patterns": [
      {
        "pattern": "(?:rtk )?git add.*",
        "description": "Add Changes",
        "regex": true
      },
      {
        "pattern": "(?:rtk )?git commit.*",
        "description": "Commit Changes",
        "regex": true
      },
      {
        "pattern": "(?:rtk )?git push.*",
        "description": "Commit Changes",
        "regex": true
      }
    ],
    "requireConfirmation": true
  },
  "version": "0.9.0-20260327"
}
